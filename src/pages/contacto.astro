---
import LineasTrabajo from "../components/lineas-trabajo.astro";
import Layout from '../layouts/BlogPost.astro';

const departamentos = [
  {
    nombre: "Ventas",
    emails: ["ventas@daytex.pe"],
  },
  {
    nombre: "Contabilidad",
    emails: ["contabilidad@daytex.pe"],
  },
  {
    nombre: "Administración",
    emails: ["administracion@daytex.com"],
  },
];
---
<Layout
	title="Contactos"
	description="Lorem ipsum dolor sit amet"
> 
    <section class="relative overflow-hidden">
  <div class="grid grid-cols-1 md:grid-cols-2 mt-16 min-h-[140px]">
    
    <div class="relative bg-offsetti-dark text-white p-8 md:p-12 flex flex-col justify-center items-end z-20
                after:content-[''] after:absolute after:inset-0 after:bg-offsetti-dark 
                after:origin-bottom-right after:transform after:skew-x-[-15deg] md:after:skew-x-[-25deg] after:z-[-1] after:translate-x-6 md:after:translate-x-12">
      
      <div class="text-right space-y-1">
        <h3 class="text-[#009EE0] font-bold uppercase tracking-[0.3em] text-[10px] md:text-xs italic">
          Estamos a tu servicio
        </h3>
        <h2 class="text-2xl md:text-4xl font-black italic uppercase tracking-tighter leading-none">
          Artes Gráficas <span class="text-white/40">|</span> <br class="md:hidden"/> 
          Imprenta <span class="text-white/40">|</span> Contacto
        </h2>
      </div>
    </div>

    <div class="bg-white p-8 md:p-12 flex items-center justify-center md:justify-start pl-12 md:pl-24">
      <h1 class="text-5xl md:text-7xl font-black tracking-tighter text-black italic leading-none group cursor-default">
        DAY<span class="text-[#009EE0] group-hover:text-black transition-colors duration-300">TEX</span>
      </h1>
    </div>

  </div>
</section>
    <section class="bg-gray-50 py-20 relative overflow-hidden">
      <div class="absolute top-0 left-0 w-full h-1 bg-[#009EE0]"></div>

      <div class="relative z-10 max-w-6xl mx-auto px-6">
        <div class="text-center mb-16 space-y-4">
          <h2 class="text-black font-black italic uppercase text-3xl md:text-5xl tracking-tighter">
            Contacto <span class="text-[#009EE0]">Directo</span>
          </h2>
          <p class="text-gray-500 text-lg md:text-xl font-light max-w-2xl mx-auto">
            El equipo de <span class="font-bold text-black italic">DAYTEX</span> estará encantado de atender cualquier duda o solicitud.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
          {departamentos.map((dep) => (
            <div class="group relative bg-white p-8 shadow-sm hover:shadow-2xl transition-all duration-500 border-b-4 border-gray-200 hover:border-[#009EE0] flex flex-col items-center text-center">
              
              <div class="w-16 h-16 bg-gray-100 rounded-full flex items-center justify-center mb-6 group-hover:bg-[#009EE0] transition-colors duration-500">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-gray-400 group-hover:text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>

              <h3 class="text-black font-black uppercase italic text-xl mb-4 tracking-tight">
                {dep.nombre}
              </h3>
              
              <div class="space-y-3 w-full">
                {dep.emails.map((email) => (
                  <a 
                    href={`mailto:${email}`} 
                    class="block py-3 px-4 bg-gray-50 text-[#009EE0] font-bold text-sm md:text-base rounded-sm hover:bg-black hover:text-white transition-all duration-300 break-all border border-transparent hover:border-black"
                  >
                    {email}
                  </a>
                ))}
              </div>

              <div class="mt-6 opacity-0 group-hover:opacity-100 transition-opacity duration-500">
                <span class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Enviar mensaje →</span>
              </div>
            </div>
          ))}
        </div>

        <div class="mt-20 text-center">
            <p class="text-[10px] font-bold text-gray-400 uppercase tracking-[0.5em]">
                Atención al cliente | Lunes a Viernes 09:00 - 18:00
            </p>
        </div>
      </div>
    </section>

    <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-24">
        
        <div class="mb-16">
        <p class="text-offsetti-blue uppercase tracking-[0.3em] text-xs font-bold mb-3">
            Contacto
        </p>
        <h2 class="text-3xl md:text-4xl font-light text-gray-800 uppercase tracking-wider">
            Estamos a su <span class="font-bold text-offsetti-dark">disposición</span>
        </h2>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
        
        <div class="space-y-12">
            <div>
            <h3 class="text-lg font-bold uppercase tracking-widest text-gray-900 mb-6 border-b-2 border-offsetti-blue w-fit">
                Oficinas y Talleres
            </h3>
            <div class="space-y-4 text-gray-600 text-lg">
                <p class="flex items-start gap-4">
                <span class="font-bold text-offsetti-dark">Dirección:</span>
                  Av. Argentina 144 Int. 1090 - 1091   Lima <br> (Galeria Unicentro)
                </p>
                <p class="flex items-start gap-4">
                  <span class="font-bold text-offsetti-dark">Local:</span>
                   1090 y 1091
                </p>
                <p class="flex items-center gap-4">
                <span class="font-bold text-offsetti-dark">Telefono:</span>
                <a href="tel:+34914137363" class="hover:text-offsetti-blue transition-colors">+51 903 209 093</a>
                </p>
                <p class="flex items-center gap-4">
                <span class="font-bold text-offsetti-dark">Correo:</span>
                <a href="mailto:info@offsetti.com" class="hover:text-offsetti-blue transition-colors text-base md:text-lg">ventas@daytex.pe</a>
                </p>
            </div>
            </div>

            <div>
            <h3 class="text-lg font-bold uppercase tracking-widest text-gray-900 mb-6 border-b-2 border-offsetti-blue w-fit">
                Horario Comercial
            </h3>
            <div class="text-gray-600 space-y-2">
                <p>Lunes a Viernes: 8:00 am - 6:00 pm</p>
                <p>Sabados: 8:00 am - 4:00 pm</p>
            </div>
            </div>
        </div>

        <div class="relative h-[400px] lg:h-full min-h-[400px] bg-gray-200 rounded-sm overflow-hidden shadow-inner border border-gray-300">

            <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d1951.0060859582045!2d-77.0458362071125!3d-12.042682792813782!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x9105c8d308153f93%3A0xe0ef148a1fd6a2eb!2sGaleria%20Unicentro%2C%20Av.%20Argentina%20144%2C%20Lima%2015079!5e0!3m2!1ses!2spe!4v1774886556328!5m2!1ses!2spe" 
              class="absolute inset-0 w-full h-full transition-all duration-500"
              style="border:0;" 
              allowfullscreen="" 
              loading="lazy">
            </iframe>
        </div>

        </div>
    </div>
    </section>
    <LineasTrabajo />
</Layout>
