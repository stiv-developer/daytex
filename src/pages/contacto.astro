---
import LineasTrabajo from "../components/lineas-trabajo.astro";
import Layout from '../layouts/BlogPost.astro';

const departamentos = [
  {
    nombre: "Dep. Comercial",
    emails: ["roberto@offsetti.com", "angel@offsetti.com"],
  },
  {
    nombre: "Administración",
    emails: ["miguel@offsetti.com", "mercedes@offsetti.com", "recepcion@offsetti.com"],
  },
  {
    nombre: "Producción",
    emails: ["angelcorral@offsetti.com", "oscar@offsetti.com"],
  },
  {
    nombre: "Presupuestos",
    emails: ["rafa@offsetti.com"],
  },
  {
    nombre: "Calidad y otros",
    emails: ["jpedrohijo@offsetti.com"],
  },
  {
    nombre: "Preimpresión",
    emails: ["ctp@offsetti.com"],
  },
];
---
<Layout
	title="Contactos"
	description="Lorem ipsum dolor sit amet"
> 
    <section>
        <div class="grid md:grid-cols-2 mt-10">
            <div class="bg-offsetti-dark text-white text-end p-5">
                <h1 class="text-xl">Estamos a tu servicio</h1>
                <h1 class="text-3xl">Artes Gráficas | Imprenta | Contacto</h1>
            </div>
            <div class="p-5">
                <h2 class="text-5xl text-center md:text-start">OFFSETTI</h2>
            </div>
        </div>
    </section>
    <section>
        <div class="relative z-10 max-w-6xl mx-auto px-6">
    <div class="text-center my-12">
      <p class="text-gray-600 text-lg md:text-xl font-light">
        El equipo de Offsetti estará encantado en atender cualquier duda o solicitud:
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-12">
      {departamentos.map((dep) => (
        <div class="bg-white rounded-[2rem] shadow-lg overflow-hidden border border-gray-100 flex flex-col items-center pb-6">
          <div class="bg-offsetti-blue w-full py-3 px-4 text-center mb-4">
            <h3 class="text-white font-bold text-lg md:text-xl">
              {dep.nombre}
            </h3>
          </div>
          
          <div class="flex flex-col items-center space-y-2 px-4">
            {dep.emails.map((email) => (
              <a 
                href={`mailto:${email}`} 
                class="text-gray-700 hover:text-offsetti-blue transition-colors text-base md:text-lg break-all text-center"
              >
                {email}
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
    </section>

    <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-24">
        
        <div class="mb-16">
        <p class="text-offsetti-blue uppercase tracking-[0.3em] text-xs font-bold mb-3">
            Contacto
        </p>
        <h2 class="text-3xl md:text-4xl font-light text-gray-800 uppercase tracking-wider">
            Estamos a su <span class="font-bold text-offsetti-dark">disposición</span>
        </h2>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
        
        <div class="space-y-12">
            <div>
            <h3 class="text-lg font-bold uppercase tracking-widest text-gray-900 mb-6 border-b-2 border-offsetti-blue w-fit">
                Oficinas y Talleres
            </h3>
            <div class="space-y-4 text-gray-600 text-lg">
                <p class="flex items-start gap-4">
                <span class="font-bold text-offsetti-dark">Dirección:</span>
                  Av. Argentina 144 Int. 1090 - 1091   Lima <br> (Galeria Unicentro)
                </p>
                <p class="flex items-start gap-4">
                  <span class="font-bold text-offsetti-dark">Local:</span>
                   1090 y 1091
                </p>
                <p class="flex items-center gap-4">
                <span class="font-bold text-offsetti-dark">Telefono:</span>
                <a href="tel:+34914137363" class="hover:text-offsetti-blue transition-colors">+51 903 209 093</a>
                </p>
                <p class="flex items-center gap-4">
                <span class="font-bold text-offsetti-dark">Correo:</span>
                <a href="mailto:info@offsetti.com" class="hover:text-offsetti-blue transition-colors text-base md:text-lg">ventas@daytex.pe</a>
                </p>
            </div>
            </div>

            <div>
            <h3 class="text-lg font-bold uppercase tracking-widest text-gray-900 mb-6 border-b-2 border-offsetti-blue w-fit">
                Horario Comercial
            </h3>
            <div class="text-gray-600 space-y-2">
                <p>Lunes a Viernes: 8:00 am - 6:00 pm</p>
                <p>Sabados: 8:00 am - 4:00 pm</p>
            </div>
            </div>
        </div>

        <div class="relative h-[400px] lg:h-full min-h-[400px] bg-gray-200 rounded-sm overflow-hidden shadow-inner border border-gray-300">

            <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d1951.0060859582045!2d-77.0458362071125!3d-12.042682792813782!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x9105c8d308153f93%3A0xe0ef148a1fd6a2eb!2sGaleria%20Unicentro%2C%20Av.%20Argentina%20144%2C%20Lima%2015079!5e0!3m2!1ses!2spe!4v1774886556328!5m2!1ses!2spe" 
              class="absolute inset-0 w-full h-full transition-all duration-500"
              style="border:0;" 
              allowfullscreen="" 
              loading="lazy">
            </iframe>
        </div>

        </div>
    </div>
    </section>
    <LineasTrabajo />
</Layout>
