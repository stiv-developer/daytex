---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

import { Image } from 'astro:assets';
import iconoDiseno from '../assets/iconos/Artes-Graficas-Madrid-Offsetti-diseno-grafico-graphic-design.svg';
import iconoPreImpresion from '../assets/iconos/Artes-Graficas-Madrid-Offsetti-diseno-grafico-graphic-design.svg';
import iconoImpresionOffset from '../assets/iconos/Artes-Graficas-Madrid-Offsetti-Impresion-Offset.svg';
import iconoImpresionDigital from '../assets/iconos/Artes-Graficas-Madrid-Offsetti-Impresion-Digital.svg';
import iconoEncuadernado from '../assets/iconos/Artes-Graficas-Madrid-Offsetti-Encuadernacion.svg';
import iconoPersonalizado from '../assets/iconos/Artes-Graficas-Madrid-Offsetti-Personalizado.svg';

const services = [
	{
    title: "Diseño Gráfico",
    description: "No multiplique sus esfuerzos. Nos encargamos del <strong>diseño de su proyecto</strong>, la <strong>producción</strong>, la <strong>personalización</strong> y el envío.",
    icon: iconoDiseno,
  },
  {
    title: "Preimpresión",
    description: "Máquinas CTP de alta tecnología, flujo de trabajo a <strong>340 lpi</strong>, plotter Sherpa y Epson, trama <strong>Sublima de Agfa</strong>.",
    icon: iconoPreImpresion,
  },
  {
    title: "Impresión offset",
    description: "<strong>Heidelberg XL</strong>, 18.000 pliegos a la hora, desde <strong>40 a 500 gr/m2</strong> de cualquier calibre, formatos <strong>25x50 a 75x105</strong>.",
    icon: iconoImpresionOffset,
  },
  {
    title: "Impresión digital",
    description: "Impresión digital <strong>Xerox</strong> de última generación, gran cantidad de soportes, acabados y formatos.",
    icon: iconoImpresionDigital,
  },
  {
    title: "Encuadernación",
    description: "Guillotinado, plegado, retractilado, estampación, engomado, hendido...",
    icon: iconoEncuadernado,
  },
  {
    title: "Personalización",
    description: "Inkjet y laser, procesos de alto rendimiento perfectos para marketing directo.",
    icon: iconoPersonalizado,
  },
]
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<section class="relative w-full h-[1000px] overflow-hidden">
  
			<div class="absolute inset-0 z-0 overflow-hidden">
				<video 
					autoplay 
					muted 
					loop 
					playsinline
					class="w-full h-full object-cover"
				>
					<source src="/src/assets/videos/Artes-Graficas-imprernta-madrid-Offsetti-2026C.mp4" type="video/mp4" />
					Tu navegador no soporta videos.
				</video>
				
				<div class="absolute inset-0 bg-black/20"></div>
			</div>

			<div class="absolute inset-0 z-10 overflow-hidden" >
				
				<div class="absolute top-0 left-0 w-[60%] h-[30%] md:h-[25%] bg-offsetti-dark
							before:content-[''] before:absolute before:inset-0
							before:bg-offsetti-dark before:origin-bottom-left
							before:transform before:-skew-x-[35deg]
							flex flex-col justify-center px-10 md:px-20 z-10">
    
					<div class="relative z-20">
						<h1 class="font-bold text-white text-2xl md:text-3xl lg:text-4xl uppercase leading-tight">
							Artes Gráficas | <span class="block md:inline">Imprenta Madrid</span>
						</h1>
						<p class="text-lg md:text-xl font-light text-white opacity-90">
							Imprenta de calidad
						</p>
					</div>
				</div>

				<div class="absolute bottom-0 right-0 w-[45%] h-[20%] bg-offsetti-blue
							after:content-[''] after:absolute after:inset-0
							after:bg-offsetti-blue after:origin-top-right
							after:transform after:-skew-x-[35deg]
							flex items-center justify-end px-10 md:px-20 z-10">

					<div class="relative z-20 text-right">
						<p class="text-white text-sm md:text-lg font-medium leading-tight">
							Más de 40 años trabajando sin descanso para ofrecer la <br class="hidden md:block"> máxima calidad.
						</p>
					</div>
				</div>
				
			</div>

		</section>
		<section class="relative w-full h-[1000px] overflow-hidden">
  
			<div class="absolute inset-0 z-0 overflow-hidden">
				<video 
					autoplay 
					muted 
					loop 
					playsinline
					class="w-full h-full object-cover"
				>
					<source src="/src/assets/videos/Artes-Graficas-imprernta-madrid-Offsetti-2026C.mp4" type="video/mp4" />
					Tu navegador no soporta videos.
				</video>
				
				<div class="absolute inset-0 bg-black/20"></div>
			</div>

			<div class="absolute inset-0 z-10 overflow-hidden" >
				
				<div class="absolute top-0 left-0 w-[60%] h-[30%] md:h-[13%] bg-offsetti-blue
							before:content-[''] before:absolute before:inset-0
							before:bg-offsetti-blue before:origin-bottom-left
							before:transform before:-skew-x-[35deg]
							flex flex-col justify-center px-10 md:px-20 z-10">
    
					<div class="relative z-20">
						<h1 class="font-bold text-white text-2xl md:text-3xl lg:text-4xl leading-tight">
							Imprenta de alta tecnología
						</h1>
					</div>
				</div>

				<div class="absolute bottom-0 right-0 w-[55%] h-[23%] bg-offsetti-pink
							after:content-[''] after:absolute after:inset-0
							after:bg-offsetti-pink after:origin-top-right
							after:transform after:-skew-x-[35deg]
							flex items-center justify-start px-10 md:px-20 z-10">

					<div class="relative z-20 text-left">
						<p class="text-white text-sm md:text-lg font-normal leading-tight">
							Para Offsetti lo más importante es el cliente, y la unica manera de estar en el <br>
							mercado es ser la más competitivo. Para los procesos de calidad contamos con la <br>
							trama Sublima de Agfa, que nos permite trabajar con una resolución de 340 Ipi, que <br>
							nos permite realizar impresiones con calidad fotográfica, ofreciendo unas <br>
							reproducciones perfectas. Este sistema implica unos requisitos técnicos dentro de la <br>
							empresa que muy pocos poseen, siendo pioneros y practicante exclusivos en España <br>
							en esta tecnología.
						</p>
					</div>
				</div>
				
			</div>

		</section>
		<section class="w-full h-[1000px] flex flex-col overflow-hidden relative bg-gray-50">
    
			<div class="relative w-[60%] h-[15%] bg-offsetti-pink
						before:content-[''] before:absolute before:inset-0
						before:bg-offsetti-pink before:origin-bottom-left
						before:transform before:-skew-x-[35deg]
						flex flex-col justify-center px-10 md:px-20 z-20">
				<div class="relative z-30">
					<h1 class="font-bold text-white text-2xl md:text-3xl lg:text-4xl leading-tight">
						CATÁLOGO DE PRODUCTOS
					</h1>
				</div>
			</div>

			<div class="flex-1 w-full relative z-10 flex items-center justify-center overflow-hidden">
				
				<div class="flex gap-8 px-10 overflow-x-auto snap-x scrollbar-hide w-full py-10">
					{/* Ejemplo de Item del Catálogo */}
					{[1, 2, 3, 4, 5].map((item) => (
						<div class="min-w-[300px] md:min-w-[400px] h-[450px] bg-white shadow-xl rounded-lg snap-center flex flex-col overflow-hidden group">
							<div class="h-2/3 bg-gray-200 overflow-hidden">
								<img src={`/producto-${item}.jpg`} alt="Producto" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
							</div>
							<div class="p-6">
								<h3 class="font-bold text-xl uppercase">Producto Imprenta {item}</h3>
								<p class="text-gray-600 text-sm mt-2">Descripción breve del producto de alta calidad.</p>
								<button class="mt-4 text-offsetti-pink font-bold uppercase text-xs tracking-widest">Ver detalles →</button>
							</div>
						</div>
					))}
				</div>
			</div>

			<div class="flex justify-end relative">
				<div class="w-[55%] h-[150px] bg-offsetti-yellow
							after:content-[''] after:absolute after:inset-0
							after:bg-offsetti-yellow after:origin-top-right
							after:transform after:-skew-x-[35deg]
							flex items-center justify-start px-10 md:px-20 z-20">
					<div class="relative z-30 text-left">
						<p class="text-black text-sm md:text-3xl font-bold leading-tight">
							Orgullosos de nuestro equipo
						</p>
					</div>
				</div>
			</div>

		</section>
		<section class=" w-full h-[1000px] overflow-hidden">
			<div class="bg-offsetti-yellow">
				<div class="flex justify-center py-5">
					<p class="text-black text-sm md:text-lg font-medium leading-tight">
						En Offsetti nos sentimos orgullosos de nuestro personal, estamos convencidos de que el equipo lo es todo, y que la <br>
						suma de esfuerzos individuales conduce a la perfección, como una máquina bien engranada. Gracias a la fideliad y <br>
						confianza de nuestros clientes aspiramos a ser una empresa de referencia en el sector, sin ellos no seriamos nada, y <br>
						seguiremos creciendo y mejorando para alcanzar la excelencia en nuestros productos y servicios. Lo más importante <br>
						sin duda sois vosotros.
					</p>
				</div>
				
			</div>
			<div class="relative w-full h-[1000px] overflow-hidden">
				<div class="absolute inset-0 z-0 overflow-hidden">
				<video 
					autoplay 
					muted 
					loop 
					playsinline
					class="w-full h-full object-cover"
				>
					<source src="/src/assets/videos/Artes-Graficas-imprernta-madrid-Offsetti-2026C.mp4" type="video/mp4" />
					Tu navegador no soporta videos.
				</video>
				
				<div class="absolute inset-0 bg-black/20"></div>
			</div>

			<div class="absolute inset-0 z-10 overflow-hidden" >
				
				<div class="absolute top-0 left-0 w-[60%] h-[30%] md:h-[7%] bg-offsetti-yellow
							before:content-[''] before:absolute before:inset-0
							before:bg-offsetti-yellow before:origin-bottom-left
							before:transform before:-skew-x-[35deg]
							flex flex-col justify-center px-10 md:px-20 z-10">
				</div>
				
			</div>
			</div>
			

		</section>
		<section class="py-20 px-6 bg-white">
			<div class="max-w-6xl mx-auto">
				<div class="text-center mb-16">
				<h2 class="text-2xl md:text-3xl font-light text-gray-800 mb-2">
					Artes Gráficas Madrid | Imprenta offset y digital
				</h2>
				<p class="text-gray-500 uppercase tracking-widest text-sm">Líneas de trabajo</p>
				</div>

				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-12 gap-y-16">
				{services.map((service) => (
					<div class="flex flex-col items-center text-center">
					<div class="w-32 h-32 mb-6 border-2 border-gray-800 rounded-2xl flex items-center justify-center p-4">
						{/* <img src={service.icon} alt={service.title} class="w-full h-auto object-contain" /> */}
						<Image src={service.icon} alt={service.title} class="w-full h-auto"/>
					</div>
					
					<h3 class="text-xl font-bold text-gray-900 mb-4">{service.title}</h3>
					
					<p class="text-gray-600 leading-relaxed text-[15px]" set:html={service.description} />
					</div>
				))}
				</div>
			</div>
		</section>
		<section class="bg-white py-16 px-6">
			<div class="max-w-4xl mx-auto text-center flex flex-col items-center">
				
				<div class="mb-10 space-y-1">
				<h2 class="text-xl md:text-2xl font-light text-gray-700">
					Artes Gráficas | Imprenta Madrid
				</h2>
				<p class="text-xl md:text-2xl font-light text-gray-700">
					Líderes en impresión offset y digital en España
				</p>
				<p class="text-xl md:text-2xl font-light text-gray-700">
					Preimpresión SUBLIMA de Agfa, hasta 340 lpi
				</p>
				</div>

				<div class="mb-6">
				<p class="text-gray-600 text-[15px] leading-relaxed">
					Diseño web, SEO, <br />
					fotografía y video:
				</p>
				<a 
					href="https://javiercasero.es" 
					target="_blank" 
					class="text-black font-bold text-lg hover:text-gray-700 transition-colors"
				>
					javiercasero.es
				</a>
				</div>

				<div class="mt-4">
				<img 
					src="/assets/logo-javier-casero.png" 
					alt="Javier Casero Fotografía" 
					class="h-28 w-auto grayscale opacity-80 hover:grayscale-0 hover:opacity-100 transition-all duration-300"
				/>
				</div>

			</div>
		</section>
		<Footer />
	</body>
</html>

<style>
    /* Ocultar scrollbar para que se vea más limpio */
    .scrollbar-hide::-webkit-scrollbar {
        display: none;
    }
    .scrollbar-hide {
        -ms-overflow-style: none;
        scrollbar-width: none;
    }
</style>
