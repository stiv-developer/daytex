---
import LineasTrabajo from "../components/lineas-trabajo.astro";
import Layout from '../layouts/BlogPost.astro';
import Portafolio from "../components/Portafolio.astro";
---

<Layout
	title="Producto"
	description="Lorem ipsum dolor sit amet"
> 
    <section class="relative w-full h-[150px] overflow-hidden">
    
        <div class="absolute top-0 left-0 w-[70%] h-full bg-offsetti-dark
                    before:content-[''] before:absolute before:inset-0
                    before:bg-offsetti-dark before:origin-bottom-left
                    before:transform before:-skew-x-[35deg]
                    flex items-center px-10 md:px-20 z-10">

            <div class="relative z-20 w-full">
                <h1 class="text-center text-white text-2xl md:text-4xl font-bold uppercase">
                    Artes Gráficas Madrid | <span class="font-light">producto</span>
                </h1>
            </div>
        </div>
    </section>
    <Portafolio />
    <LineasTrabajo />
</Layout>