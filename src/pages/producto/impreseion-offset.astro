---
import LineasTrabajo from "../../components/lineas-trabajo.astro";
import Layout from '../../layouts/BlogPost.astro';
import { Image } from 'astro:assets';

import caorusel2 from '../../assets/logistica/carousel/Artes-Graficas-Logistica-2.jpg';
import caorusel4 from '../../assets/logistica/carousel/Artes-Graficas-Logistica-4.jpg';
import caorusel6 from '../../assets/logistica/carousel/Artes-Graficas-Logistica-6.jpg';
import caorusel10 from '../../assets/logistica/carousel/Artes-Graficas-Logistica-10.jpg';

const images = [
  { src: caorusel2, alt: "Detalle vehículo Offsetti" },
  { src: caorusel4, alt: "Furgoneta comercial" },
  { src: caorusel6, alt: "Fachada Almacén Central" },
  { src: caorusel10, alt: "Stock de papel Creator" },
];
---

<Layout title="Impresión Offset" description="asd">
    <section class="relative w-full flex flex-col overflow-hidden gb-gray-50 bg-offsetti-dark">
        
        <div class="relative w-[80%] md:w-[60%] h-[70px] md:h-[150px] bg-[#009EE0]
						before:content-[''] before:absolute before:inset-0
						before:bg-[#009EE0] before:origin-bottom-left
						before:transform before:-skew-x-[35deg]
						flex flex-col justify-center px-5 md:px-10 md:px-20 z-20">
            <div class="relative z-30">
                <h1 class="font-bold text-white text-sm md:text-3xl lg:text-4xl leading-tight tracking-tighter italic uppercase">
                    Artes Grafícas <span class="text-offsetti-dark">|</span> Imprenta <span class="text-offsetti-dark">|</span> Preimpresión
                </h1>
            </div>
        </div>

        <div class="relative w-[55%] md:w-[40%] h-[50px] md:h-[150px] bg-[#009EE0]
						before:content-[''] before:absolute before:inset-0
						before:bg-[#009EE0] before:origin-bottom-left
						before:transform before:-skew-x-[35deg]
						flex flex-col justify-center px-5 md:px-10 md:px-20 z-20">
            <div class="relative z-30">
                <h1 class="font-light text-white text-sm md:text-3xl lg:text-4xl leading-tight italic tracking-tight">
                    Lineas de <span class="font-bold text-white">trabajo</span>
                </h1>
            </div>
        </div>

        <div class="bg-offsetti-dark py-24 overflow-hidden relative">
            <div class="absolute inset-0 opacity-5 pointer-events-none" 
                style="background-image: radial-gradient(circle, #fff 1.5px, transparent 1.5px); background-size: 25px 25px;">
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-2 max-w-[1300px] mx-auto gap-16 px-6 items-center relative z-10">
                
                <div class="text-white space-y-12">
                    <div>
                        <h2 class="text-[#009EE0] font-bold uppercase tracking-[0.3em] text-xs mb-3 italic">
                            Capacidad Industrial
                        </h2>
                        <h3 class="text-4xl md:text-5xl font-black italic uppercase tracking-tighter leading-none">
                            Impresión <span class="text-white/50">Offset</span>
                        </h3>
                    </div>

                    <div class="grid grid-cols-2 gap-8 border-y border-white/10 py-8">
                        <div>
                            <p class="text-[#009EE0] text-3xl font-black italic">18.000</p>
                            <p class="text-xs uppercase font-bold tracking-widest text-gray-400">Pliegos / Hora</p>
                        </div>
                        <div>
                            <p class="text-[#009EE0] text-3xl font-black italic">105<span class="text-sm ml-1 text-white">cm</span></p>
                            <p class="text-xs uppercase font-bold tracking-widest text-gray-400">Gran Formato</p>
                        </div>
                    </div>

                    <div class="space-y-8">
                        <div class="group">
                            <h4 class="text-lg font-bold text-[#009EE0] flex items-center gap-2 mb-2 italic">
                                <span class="w-2 h-2 bg-white rounded-full"></span> 
                                HEIDELBERG SPEEDMASTER XL
                            </h4>
                            <p class="text-gray-300 text-sm leading-relaxed pl-4 border-l border-white/20">
                                75X105 - 5 colores. Optimizada para <span class="text-white font-bold">Comercial & Packaging</span> con altas velocidades en cartón (80g a 400g).
                            </p>
                        </div>

                        <div class="group">
                            <h4 class="text-lg font-bold text-[#009EE0] flex items-center gap-2 mb-2 italic">
                                <span class="w-2 h-2 bg-white rounded-full"></span> 
                                KOMORI LITHRONE S40P
                            </h4>
                            <p class="text-gray-300 text-sm leading-relaxed pl-4 border-l border-white/20">
                                72X102 - 5+5 colores. <span class="text-white font-bold">Volteo automático</span> para cuatricromía + Pantone/Barniz en una sola pasada.
                            </p>
                        </div>
                    </div>

                    <div class="flex items-center gap-4 bg-white/5 p-4 rounded-sm border-l-4 border-[#009EE0]">
                        <div class="text-xs font-medium text-gray-400 uppercase tracking-wider">
                            <span class="text-white font-black">Turnos 24h</span> • 20 Cuerpos de impresión • Espectrofotometría certificada
                        </div>
                    </div>
                </div>

                <div class="relative">
                    <div class="absolute -top-4 -left-4 w-24 h-24 border-t-2 border-l-2 border-[#009EE0] z-0"></div>
                    
                    <div class="relative z-10 rounded-sm overflow-hidden shadow-2xl bg-black aspect-video group border border-white/10">
                        <video autoplay muted loop playsinline class="w-full h-full object-cover opacity-80 group-hover:opacity-100 transition-opacity duration-500">
                            <source src="/videos/Preimpresion-web-2.mp4" type="video/mp4" />
                        </video>
                        
                        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent pointer-events-none"></div>

                        <div class="absolute bottom-4 left-4 bg-[#009EE0] text-black px-4 py-1 text-[10px] font-black uppercase italic tracking-widest">
                            Production Mode
                        </div>
                    </div>
                </div>

            </div>
        </div>

        <div class="relative flex justify-end">
				
            <div class="relative w-[60%] md:w-[60%] h-[50px] md:h-[150px] bg-[#009EE0]
                after:content-[''] after:absolute after:inset-0
                after:bg-[#009EE0] after:origin-top-left
                after:transform after:-skew-x-[35deg]
                flex items-center justify-start px-10 md:px-20 z-20">
            </div>
				
        </div>

    </section>

    <section class="relative">
        <div class="absolute w-[40%] h-[50px] md:h-[150px] bg-[#009EE0]
                    before:content-[''] before:absolute before:inset-0
                    before:bg-[#009EE0] before:origin-bottom-left
                    before:transform before:-skew-x-[35deg]
                    flex flex-col justify-center px-10 md:px-20 z-30">
        </div>
        
        <div class="relative z-10 overflow-hidden w-full">
            <div class="carousel-container relative flex">
                <div id="carousel-track" class="flex animate-scroll">

                    {images.map((img) => (
                        <div class="carousel-item flex-shrink-0">
                        <div class="h-[300px] md:h-[750px] w-auto shadow-md bg-white">

                            <Image src={img.src} 
                            alt={img.alt} 
                            class="h-full w-auto object-cover" />
                        </div>
                        </div>
                    ))}

                </div>
            </div>
        </div>

    </section>

    <section class="bg-[#009EE0] py-24 relative overflow-hidden">
        <div class="absolute inset-0 opacity-10 pointer-events-none" 
            style="background-image: radial-gradient(circle, #000 1.2px, transparent 1.2px); background-size: 25px 25px;">
        </div>

        <div class="relative z-10 max-w-[1100px] mx-auto px-6">
            <div class="bg-white shadow-[30px_30px_0px_0px_rgba(0,0,0,0.15)] rounded-sm overflow-hidden border border-black/5">
            
            <div class="bg-slate-900 p-10 md:p-14 text-white relative">
                <div class="absolute top-0 right-0 p-6 opacity-20">
                    <span class="text-7xl font-black italic tracking-tighter">XL</span>
                </div>
                <div class="relative z-10 space-y-4">
                <span class="text-[#009EE0] font-bold tracking-[0.4em] uppercase text-[10px]">Standard de Excelencia</span>
                <h2 class="text-3xl md:text-6xl font-black italic tracking-tighter uppercase leading-none">
                    Heidelberg <span class="text-[#009EE0]">Speedmaster</span>
                </h2>
                <p class="text-gray-400 font-medium text-lg max-w-2xl">
                    Liderazgo indiscutible en impresión offset de alta velocidad y sostenibilidad.
                </p>
                </div>
            </div>

            <div class="p-10 md:p-14">
                <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
                
                <div class="lg:col-span-7 space-y-8">
                    <p class="text-xl text-slate-800 leading-relaxed font-light border-l-4 border-[#009EE0] pl-6">
                    En <span class="font-bold text-black italic">Offsetti</span> ponemos la tecnología que no tiene rival al servicio de tus productos. La <span class="font-bold">Heidelberg XL</span> redefine la productividad con la máxima fiabilidad del mercado.
                    </p>
                    
                    <div class="bg-gray-50 p-6 border-t border-b border-gray-100 italic text-slate-600">
                    "Combinamos esta potencia con la tecnología <span class="text-black font-bold uppercase">Sublima de Agfa</span> para resultados de preimpresión que rozan la perfección."
                    </div>

                    <div class="pt-4">
                        <h4 class="text-black font-black uppercase text-sm tracking-widest mb-4">Compromiso Eco-Responsable</h4>
                        <p class="text-slate-600 text-sm leading-relaxed">
                            La Heidelberg XL es una ingeniería eficiente: utiliza menos energía y recursos que las prensas tradicionales, garantizando una <span class="text-[#009EE0] font-bold">calidad de impresión sostenible</span> y respeto por el medio ambiente.
                        </p>
                    </div>
                </div>

                <div class="lg:col-span-5 grid grid-cols-1 gap-4">
                    <div class="bg-slate-900 text-white p-6 rounded-sm flex items-center justify-between group hover:bg-[#009EE0] transition-colors duration-300">
                        <div>
                            <p class="text-[10px] uppercase tracking-widest text-[#009EE0] group-hover:text-black font-bold">Velocidad Máxima</p>
                            <p class="text-2xl font-black italic uppercase">18.000 <span class="text-xs">pliegos/h</span></p>
                        </div>
                    </div>

                    <div class="bg-gray-100 p-6 rounded-sm flex items-center justify-between">
                        <div>
                            <p class="text-[10px] uppercase tracking-widest text-gray-400 font-bold">Resolución Óptica</p>
                            <p class="text-2xl font-black italic uppercase text-black">2.400 <span class="text-xs">ppp</span></p>
                        </div>
                    </div>

                    <div class="bg-gray-100 p-6 rounded-sm flex items-center justify-between">
                        <div>
                            <p class="text-[10px] uppercase tracking-widest text-gray-400 font-bold">Versatilidad</p>
                            <p class="text-2xl font-black italic uppercase text-black">Multimaterial</p>
                        </div>
                    </div>
                </div>
                </div>
            </div>

            <div class="bg-gray-50 px-10 py-4 flex justify-between items-center border-t border-gray-100">
                <p class="text-[9px] font-bold text-gray-400 uppercase tracking-[0.3em]">Artes Gráficas | Impresión Offset de Altísima Calidad</p>
                <div class="w-2 h-2 bg-[#009EE0] rounded-full animate-pulse"></div>
            </div>
            </div>
        </div>
    </section>
    <LineasTrabajo />
</Layout>

<style>
  .carousel-container {
    width: 100%;
  }

  .animate-scroll {
    display: flex;
    width: max-content;
    animation: scroll 40s linear infinite;
  }

  .animate-scroll:hover {
    animation-play-state: paused;
  }

  @keyframes scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  .carousel-item img {
    user-select: none;
    -webkit-user-drag: none;
  }
</style>

<script>
  function setupCarousel() {
    const track = document.getElementById('carousel-track');
    if (!track) return;
    
    const items = track.innerHTML;
    track.innerHTML = items + items;
  }
  setupCarousel();
  document.addEventListener('astro:after-swap', setupCarousel);
</script>