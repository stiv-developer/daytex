---
import LineasTrabajo from "../../components/lineas-trabajo.astro";
import Layout from '../../layouts/BlogPost.astro';
import { Image } from 'astro:assets';

import caorusel2 from '../../assets/logistica/carousel/Artes-Graficas-Logistica-2.jpg';
import caorusel4 from '../../assets/logistica/carousel/Artes-Graficas-Logistica-4.jpg';
import caorusel6 from '../../assets/logistica/carousel/Artes-Graficas-Logistica-6.jpg';
import caorusel10 from '../../assets/logistica/carousel/Artes-Graficas-Logistica-10.jpg';

const images = [
  { src: caorusel2, alt: "Detalle vehículo Offsetti" },
  { src: caorusel4, alt: "Furgoneta comercial" },
  { src: caorusel6, alt: "Fachada Almacén Central" },
  { src: caorusel10, alt: "Stock de papel Creator" },
];
---

<Layout title="PreImpresión" description="asd">
    <section class="relative w-full flex flex-col overflow-hidden gb-gray-50 bg-[#009EE0]">
        
        <div class="relative w-[80%] md:w-[60%] h-[70px] md:h-[150px] bg-offsetti-dark
						before:content-[''] before:absolute before:inset-0
						before:bg-offsetti-dark before:origin-bottom-left
						before:transform before:-skew-x-[35deg]
						flex flex-col justify-center px-5 md:px-10 md:px-20 z-20">
            <div class="relative z-30">
                <h1 class="font-bold text-white text-sm md:text-3xl lg:text-4xl leading-tight tracking-tighter italic uppercase">
                    Artes Grafícas <span class="text-[#009EE0]">|</span> Imprenta <span class="text-[#009EE0]">|</span> Preimpresión
                </h1>
            </div>
        </div>

        <div class="relative w-[55%] md:w-[40%] h-[50px] md:h-[150px] bg-offsetti-dark
						before:content-[''] before:absolute before:inset-0
						before:bg-offsetti-dark before:origin-bottom-left
						before:transform before:-skew-x-[35deg]
						flex flex-col justify-center px-5 md:px-10 md:px-20 z-20">
            <div class="relative z-30">
                <h1 class="font-light text-white text-sm md:text-3xl lg:text-4xl leading-tight italic tracking-tight">
                    Lineas de <span class="font-bold text-white">trabajo</span>
                </h1>
            </div>
        </div>

        <div class="bg-[#009EE0] py-24 overflow-hidden relative">
            <div class="absolute inset-0 opacity-10 pointer-events-none" 
                style="background-image: radial-gradient(circle, #000 1.5px, transparent 1.5px); background-size: 20px 20px;">
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-2 max-w-[1300px] mx-auto gap-16 px-6 items-center relative z-10">
                
                <div class="text-slate-900 space-y-10">
                    <header>
                        <div class="flex items-center gap-3 mb-4">
                            <span class="w-12 h-[3px] bg-black"></span>
                            <h2 class="text-black font-bold uppercase tracking-[0.2em] text-xs">
                                Tecnología de Vanguardia
                            </h2>
                        </div>
                        <h3 class="text-4xl md:text-6xl font-black leading-tight tracking-tighter italic uppercase text-white drop-shadow-sm">
                        Equipos <br/>
                        <span class="text-black">Certificados</span>
                        </h3>
                    </header>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                        <div class="bg-white/20 backdrop-blur-sm p-6 rounded-lg border-l-4 border-black">
                        <h4 class="text-lg font-bold flex items-center gap-2 mb-3 text-black">
                            Computers To Plate
                        </h4>
                        <p class="text-slate-800 text-sm leading-relaxed mb-4">
                            Láser Élite con tecnología que permite trabajar a <span class="font-black text-xl">340 DPI</span>.
                        </p>
                        <ul class="space-y-2 text-xs font-bold tracking-wide uppercase">
                            <li class="flex items-center gap-2"> AVALON N8-22S </li>
                            <li class="flex items-center gap-2"> XCALIBUR 45 AGFA </li>
                            <li class="flex items-center gap-2"> ELANTRIX 125 SX </li>
                        </ul>
                        </div>

                        <div class="bg-black/5 p-6 rounded-lg border-l-4 border-white">
                        <h4 class="text-lg font-bold flex items-center gap-2 mb-3 text-black">
                            Pruebas de Color
                        </h4>
                        <p class="text-slate-800 text-sm leading-relaxed mb-4">
                            Certificado <span class="bg-black text-white px-2 py-0.5">FOGRA 39</span> mediante espectro-fotometría.
                        </p>
                        <ul class="space-y-2 text-xs font-bold tracking-wide uppercase">
                            <li>CANON PRO 4000-S</li>
                            <li>EPSON STYLUS 9880</li>
                            <li>EPSON 9900 SPECTRO</li>
                        </ul>
                        </div>
                    </div>

                    <div class="pt-6 border-t border-black/20">
                        <p class="text-2xl md:text-3xl leading-none font-black text-white italic uppercase tracking-tighter">
                        "La calidad 8K de una imprenta"
                        </p>
                        <p class="text-black font-medium mt-2 text-lg">
                        Trama Sublima de Agfa: duplicamos la resolución estándar.
                        </p>
                    </div>
                </div>

                <div class="relative">
                    <div class="absolute -bottom-4 -right-4 w-full h-full border-2 border-black z-0"></div>
                    
                    <div class="relative z-10 rounded-sm overflow-hidden shadow-2xl bg-black aspect-video group">
                        <video autoplay muted loop playsinline class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-700">
                        <source src="/videos/Preimpresion-web-2.mp4" type="video/mp4" />
                        </video>
                        
                        <div class="absolute bottom-4 left-4 bg-black text-[#009EE0] px-4 py-2 text-xs font-black uppercase italic tracking-widest">
                            Production Mode
                        </div>
                    </div>
                </div>

            </div>
        </div>

        <div class="relative flex justify-end">
				
            <div class="relative w-[60%] md:w-[60%] h-[50px] md:h-[150px] bg-offsetti-dark
                after:content-[''] after:absolute after:inset-0
                after:bg-offsetti-dark after:origin-top-left
                after:transform after:-skew-x-[35deg]
                flex items-center justify-start px-10 md:px-20 z-20">
            </div>
				
        </div>

    </section>

    <section class="relative">
        <div class="absolute w-[40%] h-[50px] md:h-[150px] bg-offsetti-dark
                    before:content-[''] before:absolute before:inset-0
                    before:bg-offsetti-dark before:origin-bottom-left
                    before:transform before:-skew-x-[35deg]
                    flex flex-col justify-center px-10 md:px-20 z-30">
        </div>
        
        <div class="relative z-10 overflow-hidden w-full">
            <div class="carousel-container relative flex">
                <div id="carousel-track" class="flex animate-scroll">

                    {images.map((img) => (
                        <div class="carousel-item flex-shrink-0">
                        <div class="h-[300px] md:h-[750px] w-auto shadow-md bg-white">

                            <Image src={img.src} 
                            alt={img.alt} 
                            class="h-full w-auto object-cover" />
                        </div>
                        </div>
                    ))}

                </div>
            </div>
        </div>

    </section>

    <section class="bg-[#009EE0] py-24 relative overflow-hidden">
        <div class="absolute inset-0 opacity-15 pointer-events-none" 
            style="background-image: radial-gradient(circle, #000 1px, transparent 1px); background-size: 30px 30px;">
        </div>

        <div class="relative z-10 max-w-[1100px] mx-auto px-6">
            <div class="bg-white shadow-[20px_20px_0px_0px_rgba(0,0,0,0.1)] rounded-sm overflow-hidden">
            
            <div class="bg-slate-900 p-8 md:p-12 text-white">
                <div class="flex flex-col md:flex-row md:items-end justify-between gap-6">
                <div class="space-y-2">
                    <span class="text-[#009EE0] font-bold tracking-[0.3em] uppercase text-xs italic">Tecnología de Preimpresión</span>
                    <h2 class="text-3xl md:text-5xl font-black italic tracking-tighter uppercase leading-none">
                    Sublima <span class="text-[#009EE0]">de AGFA</span>
                    </h2>
                </div>
                <p class="text-gray-400 text-sm font-medium border-l border-gray-700 pl-4 md:max-w-[300px]">
                    La calidad 8K de las artes gráficas: detalle y profundidad sin precedentes.
                </p>
                </div>
            </div>

            <div class="p-8 md:p-12 space-y-12">
                
                <div class="max-w-3xl">
                <p class="text-xl text-slate-700 leading-relaxed font-light">
                    En <span class="font-bold text-black uppercase italic">Offsetti</span> combinamos lo mejor de dos mundos: el tramado aleatorio y el estocástico. El resultado es una imagen <span class="text-[#009EE0] font-bold italic">nítida y realista</span> con una resolución excepcional.
                </p>
                </div>

                <hr class="border-gray-100" />

                <div>
                <h4 class="text-black font-black uppercase tracking-tighter text-2xl mb-8 italic">
                    Ventajas del Sistema
                </h4>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                    <div class="space-y-3">
                    <div class="w-10 h-10 bg-[#009EE0] flex items-center justify-center text-white font-black italic">01</div>
                    <h5 class="font-bold text-lg leading-tight uppercase">Imagen Superior</h5>
                    <p class="text-sm text-slate-600 leading-relaxed">Puntos más uniformes y suaves para una nitidez excepcional en altas lineaturas.</p>
                    </div>
                    <div class="space-y-3">
                    <div class="w-10 h-10 bg-black flex items-center justify-center text-white font-black italic">02</div>
                    <h5 class="font-bold text-lg leading-tight uppercase">Integración Total</h5>
                    <p class="text-sm text-slate-600 leading-relaxed">Tecnología aplicada automáticamente en el RIP, sin demoras en el flujo de trabajo.</p>
                    </div>
                    <div class="space-y-3">
                    <div class="w-10 h-10 bg-gray-200 flex items-center justify-center text-black font-black italic">03</div>
                    <h5 class="font-bold text-lg leading-tight uppercase">Máximo Valor</h5>
                    <p class="text-sm text-slate-600 leading-relaxed">Calidad de alta gama a precios competitivos para todos tus proyectos.</p>
                    </div>
                </div>
                </div>

                <div class="bg-gray-50 p-8 rounded-sm">
                <p class="font-bold text-xs uppercase tracking-widest text-gray-400 mb-6 text-center">Aplicaciones Ideales</p>
                <div class="flex flex-col md:flex-row gap-8 justify-between">
                    <div class="flex-1 text-center md:text-left">
                    <h6 class="font-black text-black italic text-xl">Comercial</h6>
                    <p class="text-xs text-slate-500 uppercase mt-1">Folletos, Revistas, Catálogos</p>
                    </div>
                    <div class="w-px bg-gray-200 hidden md:block"></div>
                    <div class="flex-1 text-center md:text-left">
                    <h6 class="font-black text-black italic text-xl">Industrial</h6>
                    <p class="text-xs text-slate-500 uppercase mt-1">Etiquetas, Envases, Packaging</p>
                    </div>
                    <div class="w-px bg-gray-200 hidden md:block"></div>
                    <div class="flex-1 text-center md:text-left">
                    <h6 class="font-black text-black italic text-xl">Bellas Artes</h6>
                    <p class="text-xs text-slate-500 uppercase mt-1">Obras de Arte y Fotografía</p>
                    </div>
                </div>
                </div>

            </div>

            <div class="bg-gray-100 p-4 text-center">
                <p class="text-[10px] font-bold text-gray-400 uppercase tracking-[0.5em]">
                Artes Gráficas Offsetti | Preimpresión de altísimo nivel
                </p>
            </div>
            </div>
        </div>
    </section>
    <LineasTrabajo />
</Layout>

<style>
  .carousel-container {
    width: 100%;
  }

  .animate-scroll {
    display: flex;
    width: max-content;
    animation: scroll 40s linear infinite;
  }

  .animate-scroll:hover {
    animation-play-state: paused;
  }

  @keyframes scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  .carousel-item img {
    user-select: none;
    -webkit-user-drag: none;
  }
</style>

<script>
  function setupCarousel() {
    const track = document.getElementById('carousel-track');
    if (!track) return;
    
    const items = track.innerHTML;
    track.innerHTML = items + items;
  }
  setupCarousel();
  document.addEventListener('astro:after-swap', setupCarousel);
</script>