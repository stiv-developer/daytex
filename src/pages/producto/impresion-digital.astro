---
import LineasTrabajo from "../../components/lineas-trabajo.astro";
import Layout from '../../layouts/BlogPost.astro';
import { Image } from 'astro:assets';

import caorusel2 from '../../assets/logistica/carousel/Artes-Graficas-Logistica-2.jpg';
import caorusel4 from '../../assets/logistica/carousel/Artes-Graficas-Logistica-4.jpg';
import caorusel6 from '../../assets/logistica/carousel/Artes-Graficas-Logistica-6.jpg';
import caorusel10 from '../../assets/logistica/carousel/Artes-Graficas-Logistica-10.jpg';

const images = [
  { src: caorusel2, alt: "Detalle vehículo Offsetti" },
  { src: caorusel4, alt: "Furgoneta comercial" },
  { src: caorusel6, alt: "Fachada Almacén Central" },
  { src: caorusel10, alt: "Stock de papel Creator" },
];
---

<Layout title="Impresión Digital" description="asd">
    <section class="relative w-full flex flex-col overflow-hidden gb-gray-50 bg-[#E6007E]">
        
        <div class="relative w-[80%] md:w-[60%] h-[70px] md:h-[150px] bg-offsetti-dark
						before:content-[''] before:absolute before:inset-0
						before:bg-offsetti-dark before:origin-bottom-left
						before:transform before:-skew-x-[35deg]
						flex flex-col justify-center px-5 md:px-10 md:px-20 z-20">
            <div class="relative z-30">
                <h1 class="font-bold text-white text-sm md:text-3xl lg:text-4xl leading-tight tracking-tighter italic uppercase">
                    Artes Grafícas <span class="text-[#009EE0]">|</span> Imprenta <span class="text-[#009EE0]">|</span> Impresión Digital y Gran Formato
                </h1>
            </div>
        </div>

        <div class="relative w-[55%] md:w-[40%] h-[50px] md:h-[150px] bg-offsetti-dark
						before:content-[''] before:absolute before:inset-0
						before:bg-offsetti-dark before:origin-bottom-left
						before:transform before:-skew-x-[35deg]
						flex flex-col justify-center px-5 md:px-10 md:px-20 z-20">
            <div class="relative z-30">
                <h1 class="font-light text-white text-sm md:text-3xl lg:text-4xl leading-tight italic tracking-tight">
                    Lineas de <span class="font-bold text-white">trabajo</span>
                </h1>
            </div>
        </div>

        <div class="bg-[#E6007E] py-24 overflow-hidden relative">
            <div class="absolute inset-0 opacity-10 pointer-events-none" 
                style="background-image: radial-gradient(circle, #fff 1.5px, transparent 1.5px); background-size: 25px 25px;">
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-2 max-w-[1300px] mx-auto gap-16 px-6 items-center relative z-10">
                
                <div class="text-white space-y-10">
                <header>
                    <div class="flex items-center gap-3 mb-4">
                        <span class="w-12 h-[3px] bg-black"></span>
                        <h2 class="text-black font-bold uppercase tracking-[0.3em] text-xs italic">
                            Agilidad y Personalización
                        </h2>
                    </div>
                    <h3 class="text-4xl md:text-6xl font-black italic tracking-tighter uppercase leading-none">
                    Impresión <br/>
                    <span class="text-white">Digital & <span class="text-black">Látex</span></span>
                    </h3>
                </header>

                <div class="space-y-8">
                    <div class="bg-white/10 backdrop-blur-md p-6 border-l-4 border-black">
                    <h4 class="text-xl font-black italic uppercase text-black mb-2">Ricoh Pro C9210</h4>
                    <p class="text-white/90 text-sm leading-relaxed mb-4">
                        Especialistas en tiradas personalizadas medias y pequeñas con tiempos récord.
                    </p>
                    <ul class="grid grid-cols-1 md:grid-cols-2 gap-y-2 text-[11px] font-bold uppercase tracking-wide">
                        <li class="flex items-center gap-2"><span class="w-2 h-2 bg-black rotate-45"></span> 70cm de largo</li>
                        <li class="flex items-center gap-2"><span class="w-2 h-2 bg-black rotate-45"></span> 135 pág/minuto</li>
                        <li class="flex items-center gap-2 text-black"><span class="w-2 h-2 bg-black rotate-45"></span> Soportes Especiales</li>
                        <li class="flex items-center gap-2"><span class="w-2 h-2 bg-black rotate-45"></span> Tinta Tóner Élite</li>
                    </ul>
                    </div>

                    <div class="bg-black p-6 shadow-2xl">
                    <div class="flex justify-between items-start mb-4">
                        <h4 class="text-xl font-black italic uppercase text-[#E6007E]">HP R530 Látex</h4>
                        <span class="bg-[#E6007E] text-black text-[10px] font-black px-2 py-1 italic uppercase">Revolución</span>
                    </div>
                    <p class="text-gray-400 text-sm leading-relaxed mb-4">
                        Tecnología híbrida (rígidos y bobina) con sistema <span class="text-white">HP Pixel Control</span>.
                    </p>
                    <div class="grid grid-cols-1 gap-2 text-[11px] font-medium text-gray-300">
                        <p class="flex items-center gap-2"><span class="text-[#E6007E]">✔</span> Pintura sobre soportes hasta 5cm de grosor.</p>
                        <p class="flex items-center gap-2"><span class="text-[#E6007E]">✔</span> Máxima calidad conocida en el sector.</p>
                        <p class="flex items-center gap-2"><span class="text-[#E6007E]">✔</span> Versatilidad total en rígidos y bobinas.</p>
                    </div>
                    </div>
                </div>
                </div>

                <div class="relative">
                <div class="absolute -top-6 -right-6 w-32 h-32 border-r-4 border-t-4 border-black z-0"></div>
                
                <div class="relative z-10 rounded-sm overflow-hidden shadow-2xl bg-black aspect-video group">
                    <video autoplay muted loop playsinline class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-700 opacity-80 group-hover:opacity-100">
                    <source src="/videos/Preimpresion-web-2.mp4" type="video/mp4" />
                    </video>
                    
                    <div class="absolute inset-0 bg-gradient-to-tr from-black/60 via-transparent to-[#E6007E]/20"></div>

                    <div class="absolute bottom-4 right-4 bg-black text-[#E6007E] px-4 py-2 text-[10px] font-black uppercase italic tracking-widest border border-[#E6007E]/30">
                        Digital Lab Mode
                    </div>
                </div>
                </div>

            </div>
        </div>

        <div class="relative flex justify-end">
				
            <div class="relative w-[60%] md:w-[60%] h-[50px] md:h-[150px] bg-offsetti-dark
                after:content-[''] after:absolute after:inset-0
                after:bg-offsetti-dark after:origin-top-left
                after:transform after:-skew-x-[35deg]
                flex items-center justify-start px-10 md:px-20 z-20">
            </div>
				
        </div>

    </section>
    
    <section class="relative">
        <div class="absolute w-[40%] h-[50px] md:h-[150px] bg-offsetti-dark
                    before:content-[''] before:absolute before:inset-0
                    before:bg-offsetti-dark before:origin-bottom-left
                    before:transform before:-skew-x-[35deg]
                    flex flex-col justify-center px-10 md:px-20 z-30">
        </div>
        
        <div class="relative z-10 overflow-hidden w-full">
            <div class="carousel-container relative flex">
                <div id="carousel-track" class="flex animate-scroll">

                    {images.map((img) => (
                        <div class="carousel-item flex-shrink-0">
                        <div class="h-[300px] md:h-[750px] w-auto shadow-md bg-white">

                            <Image src={img.src} 
                            alt={img.alt} 
                            class="h-full w-auto object-cover" />
                        </div>
                        </div>
                    ))}

                </div>
            </div>
        </div>

    </section>

    <section class="bg-[#E6007E] py-24 relative overflow-hidden">
        <div class="absolute inset-0 opacity-15 pointer-events-none" 
            style="background-image: radial-gradient(circle, #000 1.2px, transparent 1.2px); background-size: 25px 25px;">
        </div>

        <div class="relative z-10 max-w-[1150px] mx-auto px-6">
            <div class="bg-white shadow-[30px_30px_0px_0px_rgba(0,0,0,0.2)] rounded-sm overflow-hidden">
            
            <div class="bg-slate-900 p-10 md:p-14 text-white relative">

                <div class="relative z-10">
                
                <span class="text-[#E6007E] font-bold tracking-[0.4em] uppercase text-[10px] italic">Tecnología de Vanguardia</span>
                
                <h2 class="text-3xl md:text-6xl font-black italic tracking-tighter uppercase leading-none mt-2">
                    Impresión <span class="text-[#E6007E]">Digital</span>
                </h2>
                
                <p class="text-gray-400 font-medium text-lg mt-4 max-w-2xl leading-tight">
                    Calidad offset en hoja cortada y soluciones sostenibles de gran formato.
                </p>
                </div>

            </div>

            <div class="p-10 md:p-14 space-y-16">
                
                <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-start">
                <div class="lg:col-span-7 space-y-6">
                    <h3 class="text-2xl font-black italic uppercase text-black flex items-center gap-3">
                    <span class="w-8 h-[2px] bg-[#E6007E]"></span> Ricoh Pro C9210
                    </h3>
                    <p class="text-slate-700 leading-relaxed font-light text-lg">
                    La revolución de la hoja cortada. Ofrece una calidad de imagen excepcional, comparable a la impresión offset, gracias a su sistema de <span class="text-[#E6007E] font-bold">inyección de 12 canales</span> y tintas pigmentadas de alta densidad.
                    </p>
                    <div class="bg-gray-50 p-6 border-l-4 border-black">
                    <p class="text-sm text-slate-600 italic">
                        "Versatilidad total: desde papeles texturizados y sobres hasta traslúcidos, con un consumo energético optimizado para el cuidado del medio ambiente."
                    </p>
                    </div>
                </div>
                
                <div class="lg:col-span-5 bg-slate-50 p-8 rounded-sm space-y-6 border border-gray-100">
                    <div>
                    <p class="text-[10px] font-bold uppercase tracking-widest text-gray-400">Rendimiento Color</p>
                    <p class="text-4xl font-black italic text-black">135 <span class="text-sm font-normal">ppm</span></p>
                    </div>
                    <div class="h-px bg-gray-200"></div>
                    <div>
                    <p class="text-[10px] font-bold uppercase tracking-widest text-gray-400">Blanco y Negro</p>
                    <p class="text-4xl font-black italic text-black">115 <span class="text-sm font-normal">ppm</span></p>
                    </div>
                </div>
                </div>

                <hr class="border-gray-100" />

                <div class="grid grid-cols-1 lg:grid-cols-12 gap-10">
                <div class="lg:col-span-12">
                    <h3 class="text-2xl font-black italic uppercase text-black flex items-center gap-3 mb-8">
                    <span class="w-8 h-[2px] bg-[#E6007E]"></span> HP R530 <span class="text-gray-400">| Sostenibilidad Látex</span>
                    </h3>
                </div>
                
                <div class="lg:col-span-6 space-y-4">
                    <p class="text-slate-700 leading-relaxed font-medium">
                    Los beneficios de la tinta látex HP son inigualables en el mercado de gran formato:
                    </p>
                    <ul class="space-y-3">
                    {[
                        "Película fina y flexible que evita agrietados",
                        "Sin relieves ni brillos artificiales",
                        "Alta resistencia al rayado, agua y sol sin laminados",
                        "Emisiones tóxicas nulas y sin disolventes agresivos"
                    ].map((item) => (
                        <li class="flex items-start gap-3 text-sm text-slate-600">
                        <span class="text-[#E6007E] font-bold mt-0.5">/</span> {item}
                        </li>
                    ))}
                    </ul>
                </div>

                <div class="lg:col-span-6 flex items-center justify-center bg-black p-10 relative overflow-hidden group">
                    <div class="relative z-10 text-center">
                        <p class="text-[#E6007E] font-black text-5xl italic leading-none">ECO</p>
                        <p class="text-white font-bold uppercase tracking-[0.3em] text-[10px] mt-2">Impresión Sostenible</p>
                    </div>
                    <div class="absolute inset-0 opacity-20 bg-[url('/img/pattern.png')] group-hover:scale-110 transition-transform duration-700"></div>
                </div>
                </div>

            </div>

            <div class="bg-gray-100 px-10 py-4 flex justify-between items-center">
                <p class="text-[9px] font-bold text-gray-400 uppercase tracking-[0.3em]">
                Artes Gráficas Offsetti | Digital vanguardia & eco-printing
                </p>
                <div class="flex gap-2">
                    <div class="w-1.5 h-1.5 bg-[#E6007E] rounded-full"></div>
                    <div class="w-1.5 h-1.5 bg-black rounded-full"></div>
                </div>
            </div>
            </div>
        </div>
    </section>
    <LineasTrabajo />
</Layout>

<style>
  .carousel-container {
    width: 100%;
  }

  .animate-scroll {
    display: flex;
    width: max-content;
    animation: scroll 40s linear infinite;
  }

  .animate-scroll:hover {
    animation-play-state: paused;
  }

  @keyframes scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  .carousel-item img {
    user-select: none;
    -webkit-user-drag: none;
  }
</style>

<script>
  function setupCarousel() {
    const track = document.getElementById('carousel-track');
    if (!track) return;
    
    const items = track.innerHTML;
    track.innerHTML = items + items;
  }
  setupCarousel();
  document.addEventListener('astro:after-swap', setupCarousel);
</script>