---
import { Image } from 'astro:assets';
import iconoDiseno from '../assets/iconos/Artes-Graficas-Madrid-Offsetti-diseno-grafico-graphic-design.svg';
import iconoPreImpresion from '../assets/iconos/Artes-Graficas-Madrid-Offsetti-diseno-grafico-graphic-design.svg';
import iconoImpresionOffset from '../assets/iconos/Artes-Graficas-Madrid-Offsetti-Impresion-Offset.svg';
import iconoImpresionDigital from '../assets/iconos/Artes-Graficas-Madrid-Offsetti-Impresion-Digital.svg';
import iconoEncuadernado from '../assets/iconos/Artes-Graficas-Madrid-Offsetti-Encuadernacion.svg';
import iconoPersonalizado from '../assets/iconos/Artes-Graficas-Madrid-Offsetti-Personalizado.svg';

const services = [
	{
    title: "Diseño Gráfico",
    description: "No multiplique sus esfuerzos. Nos encargamos del <strong>diseño de su proyecto</strong>, la <strong>producción</strong>, la <strong>personalización</strong> y el envío.",
    icon: iconoDiseno,
  },
  {
    title: "Preimpresión",
    description: "Máquinas CTP de alta tecnología, flujo de trabajo a <strong>340 lpi</strong>, plotter Sherpa y Epson, trama <strong>Sublima de Agfa</strong>.",
    icon: iconoPreImpresion,
  },
  {
    title: "Impresión offset",
    description: "<strong>Heidelberg XL</strong>, 18.000 pliegos a la hora, desde <strong>40 a 500 gr/m2</strong> de cualquier calibre, formatos <strong>25x50 a 75x105</strong>.",
    icon: iconoImpresionOffset,
  },
  {
    title: "Impresión digital",
    description: "Impresión digital <strong>Xerox</strong> de última generación, gran cantidad de soportes, acabados y formatos.",
    icon: iconoImpresionDigital,
  },
  {
    title: "Encuadernación",
    description: "Guillotinado, plegado, retractilado, estampación, engomado, hendido...",
    icon: iconoEncuadernado,
  },
  {
    title: "Personalización",
    description: "Inkjet y laser, procesos de alto rendimiento perfectos para marketing directo.",
    icon: iconoPersonalizado,
  },
]
---

<section class="py-20 px-6 bg-white">
    <div class="max-w-6xl mx-auto">
        <div class="text-center mb-16">
            <h2 class="text-2xl md:text-3xl font-light text-gray-800 mb-2">
                Impresión offset y digital en Madrid | Líneas de trabajo
            </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-12 gap-y-16">
        {services.map((service) => (
            <div class="flex flex-col items-center text-center">
            <div class="w-32 h-32 mb-6 border-2 border-gray-800 rounded-2xl flex items-center justify-center p-4">
                <Image src={service.icon} alt={service.title} class="w-full h-auto"/>
            </div>
            
            <h3 class="text-xl font-bold text-gray-900 mb-4">{service.title}</h3>
            
            <p class="text-gray-600 leading-relaxed text-[15px]">service.description</p>
            </div>
        ))}
        </div>
    </div>
</section>