---
// src/components/Footer.astro
// Puedes personalizar los enlaces aquí
const lineasTrabajo = [
  "Diseño Gráfico",
  "Preimpresión",
  "Impresión offset",
  "Impresión digital",
  "Encuadernación",
  "Personalización",
  "Producto",
];

const enlacesLegales = [
  { text: "Política de privacidad", href: "/privacidad" },
  { text: "Política de cookies", href: "/cookies" },
  { text: "Aviso legal", href: "/aviso-legal" },
];
---

<footer class="w-full font-sans text-white">
  <div class="bg-offsetti-blue pt-16 pb-12 px-6 md:px-12 lg:px-24 position-relative">
    <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 text-[15px]">
      
      <div>
        <h3 class="font-bold text-lg mb-6 uppercase tracking-wider">Líneas de trabajo</h3>
        <ul class="space-y-3">
          {lineasTrabajo.map((item) => (
            <li class="flex items-center gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-2 h-2 fill-current" viewBox="0 0 8 8">
                <circle cx="4" cy="4" r="3" />
              </svg>
              <a href="#" class="hover:text-gray-200 transition-colors">{item}</a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="font-bold text-lg mb-6 invisible uppercase tracking-wider">Legales</h3> <ul class="space-y-3">
          {enlacesLegales.map((link) => (
            <li class="flex items-center gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-2 h-2 fill-current" viewBox="0 0 8 8">
                <circle cx="4" cy="4" r="3" />
              </svg>
              <a href={link.href} class="hover:text-gray-200 transition-colors">{link.text}</a>
            </li>
          ))}
        </ul>
      </div>

      <div class="space-y-2 leading-relaxed">
        <p>Av. del Ingeniero Conde de Torroja, 21</p>
        <p>28022</p>
        <p>Madrid</p>
        <p class="pt-2">91 413 73 63</p>
      </div>

      <div class="flex flex-col items-center md:items-start lg:items-center text-center md:text-left lg:text-center">
        <p class="font-bold text-lg mb-6 uppercase tracking-wider md:invisible lg:visible">Offsetti Artes Gráficas</p>
        <img 
          src="/logo-offsetti-white.png" 
          alt="Offsetti Logo Blanco" 
          class="h-24 w-auto mb-4" 
        />
        </div>
    </div>

    <!-- <a href="#top" class="absolute bottom-4 right-4 bg-[#005a87] p-3 rounded-sm hover:bg-[#004a70] transition-colors" aria-label="Volver arriba">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 15l7-7 7 7" />
      </svg>
    </a> -->
  </div>

  <div class="bg-[#005a87] py-4 px-6 md:px-12 lg:px-24 text-[13px]">
    <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-2">
      <p class="font-medium">Offsetti Artes Gráficas | Imprenta</p>
    </div>
  </div>
</footer>