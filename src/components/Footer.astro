---
// src/components/Footer.astro
// Puedes personalizar los enlaces aquí
const lineasTrabajo = [
  "Diseño Gráfico",
  "Preimpresión",
  "Impresión offset",
  "Impresión digital",
  "Encuadernación",
  "Personalización",
  "Producto",
];

const enlacesLegales = [
  { text: "Política de privacidad", href: "/privacidad" },
  { text: "Política de cookies", href: "/cookies" },
  { text: "Aviso legal", href: "/aviso-legal" },
];
---

<footer class="w-full font-sans text-white">
  <div class="bg-[#009EE0] pt-20 pb-12 px-6 md:px-12">
    <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 text-[14px]">
      
      <div>
        <h3 class="font-black italic uppercase tracking-tighter text-xl mb-8 border-b border-white/20 pb-2">
          Líneas de <span class="text-black">Trabajo</span>
        </h3>
        <ul class="space-y-3">
          {lineasTrabajo.map((item) => (
            <li class="group">
              <a href="#" class="flex items-center gap-2 text-white/80 hover:text-white transition-all duration-300 group-hover:translate-x-1">
                <span class="w-1 h-1 bg-black rounded-full"></span>
                {item}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="font-black italic uppercase tracking-tighter text-xl mb-8 border-b border-white/20 pb-2">
          Información <span class="text-black">Legal</span>
        </h3>
        <ul class="space-y-3">
          {enlacesLegales.map((link) => (
            <li class="group">
              <a href={link.href} class="flex items-center gap-2 text-white/80 hover:text-white transition-all duration-300 group-hover:translate-x-1">
                <span class="w-1 h-1 bg-white rounded-full"></span>
                {link.text}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="font-black italic uppercase tracking-tighter text-xl mb-8 border-b border-white/20 pb-2">
          Sede <span class="text-black">Central</span>
        </h3>
        <div class="space-y-4 text-white/90">
          <div class="flex gap-3">
            <svg class="w-5 h-5 text-black shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            <p class="leading-snug">
              Av. Argentina 144 Int. 1090-1091 <br/>
              <span class="text-black font-bold uppercase text-[11px]">Galería Unicentro - Lima</span>
            </p>
          </div>
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            <p class="font-bold">+51 903 209 093</p>
          </div>
        </div>
      </div>

      <div class="flex flex-col items-center lg:items-end justify-center">
        <div class="text-right">
          <p class="text-5xl md:text-6xl font-black tracking-tighter text-white italic leading-none">
            DAY<span class="text-black">TEX</span>
          </p>
          <p class="text-[10px] uppercase tracking-[0.4em] font-bold text-black mt-2">
            Artes Gráficas | Lima
          </p>
        </div>
      </div>
    </div>
  </div>

  <div class="bg-black py-6 px-6 md:px-12 border-t border-white/10">
    <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-4 text-[11px] uppercase tracking-widest text-gray-500 font-bold">
      <p>© 2026 DAYTEX. Todos los derechos reservados.</p>
      <div class="flex gap-6">
          <span class="text-white/20">Impresión de altísimo nivel</span>
      </div>
    </div>
  </div>
</footer>