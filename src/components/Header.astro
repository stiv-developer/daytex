---

---

<header class="w-full font-sans">
  <div class="bg-white border-b border-gray-100 py-2 px-4 md:px-10">
    <div class="max-w-7xl flex items-center gap-6 text-sm text-gray-700">
      <div class="flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        <span>+34 914 13 73 63</span>
      </div>
      <div class="flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
        <a href="mailto:offsetti@offsetti.com" class="hover:underline">offsetti@offsetti.com</a>
      </div>
    </div>
  </div>

  <div class="bg-white py-4 px-4 md:px-10">
    <div class="w-full flex items-center justify-between">
      
      <div class="flex-shrink-0">
		<h1 class="text-xl">Logo</h1>
      </div>

      <nav class="hidden lg:flex items-center gap-8 text-[15px] font-bold text-gray-800 uppercase tracking-tight">
        <a href="/" class="text-black">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
          </svg>
        </a>
        
        <div class="relative group cursor-pointer flex items-center gap-1">
          <span>Líneas de trabajo</span>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </div>

        <a href="/producto" class="hover:text-blue-600 transition-colors">Producto</a>
        <a href="/logistica" class="hover:text-blue-600 transition-colors">Logística</a>
        <a href="/actualidad" class="hover:text-blue-600 transition-colors">Actualidad</a>
        <a href="/imprenta-ecologica" class="hover:text-blue-600 transition-colors">Imprenta ecológica</a>
        <a href="/contacto" class="hover:text-blue-600 transition-colors">Contacto</a>

        <button class="text-gray-800 hover:text-blue-600">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </button>
      </nav>

      <div class="lg:hidden">
        <button class="p-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />
          </svg>
        </button>
      </div>

    </div>
  </div>
</header>
