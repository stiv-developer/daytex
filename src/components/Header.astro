---
import { Image } from 'astro:assets';
import logo from '../assets/logos/DAYTEX.svg';
---

<header class="w-full font-sans sticky top-0 z-50">
  <div class="bg-slate-900 py-2 px-4 md:px-10 border-b border-white/5">
    <div class="max-w-7xl mx-auto flex flex-wrap items-center justify-between gap-4 text-[11px] md:text-xs font-bold uppercase tracking-widest text-gray-400">
      
      <div class="flex items-center gap-6">
        <a href="tel:+51903209093" class="flex items-center gap-2 hover:text-[#009EE0] transition-colors duration-300">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-[#009EE0]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          <span>+51 903 209 093</span>
        </a>

        <a href="mailto:ventas@daytex.pe" class="flex items-center gap-2 hover:text-[#009EE0] transition-colors duration-300">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-[#009EE0]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          <span class="lowercase font-medium tracking-normal text-gray-300">ventas@daytex.pe</span>
        </a>
      </div>

      <div class="hidden md:flex items-center gap-2">
        <span class="w-1.5 h-1.5 bg-[#009EE0] rounded-full animate-pulse"></span>
        <span class="text-[10px]">Artes Gráficas | Lima, Perú</span>
      </div>
    </div>
  </div>

  <div class="bg-white py-4 px-4 md:px-10 relative">
    <div class="w-full flex items-center justify-between">
      
      <div class="flex-shrink-0">
		    <!-- <h1 class="text-2xl md:text-3xl font-extrabold tracking-tighter transition-transform group-hover:scale-105">DAYTEX</h1> -->
         <Image src={logo} alt="logo daytex" class="w-16 h-16"/>
      </div>

      <nav class="hidden lg:flex items-center gap-8 text-[15px] font-bold text-gray-800 uppercase tracking-tight">
        <a href="/" class="text-black">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
          </svg>
        </a>
        
        <div class="relative group cursor-pointer flex items-center gap-1 h-full py-4">

          <span class="hover:text-offsetti-blue transition-colors">Líneas de trabajo</span>

          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>

          <div class="absolute top-full left-0 w-64 bg-white shadow-xl border-t-2 border-offsetti-blue 
                      invisible opacity-0 group-hover:visible group-hover:opacity-100 
                      transition-all duration-300 transform translate-y-2 group-hover:translate-y-0 z-50">
              <ul class="py-2">
                  <li>
                      <a href="/producto/diseno-grafico" class="block px-6 py-3 text-sm text-gray-700 hover:bg-gray-50 hover:text-offsetti-blue border-b border-gray-50">
                          Diseño Gráfico
                      </a>
                  </li>
                  <li>
                      <a href="/producto/preimpresion" class="block px-6 py-3 text-sm text-gray-700 hover:bg-gray-50 hover:text-offsetti-blue border-b border-gray-50">
                          Preimpresión
                      </a>
                  </li>
                  <li>
                      <a href="/producto/impreseion-offset" class="block px-6 py-3 text-sm text-gray-700 hover:bg-gray-50 hover:text-offsetti-blue border-b border-gray-50">
                          Impresión offset
                      </a>
                  </li>
                  <li>
                      <a href="/producto/impresion-digital" class="block px-6 py-3 text-sm text-gray-700 hover:bg-gray-50 hover:text-offsetti-blue">
                          Impresión digital
                      </a>
                  </li>
                  <li>
                      <a href="/producto/encuadernacion" class="block px-6 py-3 text-sm text-gray-700 hover:bg-gray-50 hover:text-offsetti-blue">
                          Encuadernación
                      </a>
                  </li>
                  <li>
                      <a href="/producto/personalizacion" class="block px-6 py-3 text-sm text-gray-700 hover:bg-gray-50 hover:text-offsetti-blue">
                          Personalización
                      </a>
                  </li>
              </ul>
          </div>

        </div>

        <a href="/producto" class="hover:text-blue-600 transition-colors cursor-pointer">Producto</a>
        <a href="/logistica" class="hover:text-blue-600 transition-colors cursor-pointer">Logística</a>
        <a href="/imprenta-ecologica" class="hover:text-blue-600 transition-colors cursor-pointer">Imprenta ecológica</a>
        <a href="/contacto" class="hover:text-blue-600 transition-colors cursor-pointer">Contacto</a>
      </nav>

      <div class="lg:hidden">
        <button id="menu-toggle" class="p-2">
          <svg id="menu-icon" xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />
          </svg>
        </button>
      </div>

      <div id="mobile-menu" class="hidden lg:hidden absolute top-full left-0 w-full bg-white border-t border-gray-100 shadow-xl z-50">
  <nav class="flex flex-col p-6 text-base font-bold text-gray-800 uppercase">
    <a href="/" class="border-b border-gray-50 py-4">Inicio</a>
    
    <div class="border-b border-gray-50">
      <button id="mobile-submenu-btn" class="w-full flex justify-between items-center py-4 uppercase font-bold focus:outline-none">
        <span>Líneas de trabajo</span>
        <svg id="mobile-arrow" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
        </svg>
      </button>
      
      <div id="mobile-submenu-list" class="hidden flex-col bg-gray-50 px-4 pb-4 gap-3 normal-case font-normal text-gray-600">
        <a href="/producto/diseno-grafico" class="py-2 border-l-2 border-offsetti-blue pl-4 mt-2">Diseño Gráfico</a>
        <a href="/producto/preimpresion" class="py-2 border-l-2 border-offsetti-blue pl-4 mt-2">Preimpresión</a>
        <a href="/producto/impreseion-offset" class="py-2 border-l-2 border-offsetti-blue pl-4 mt-2">Impresión offset</a>
        <a href="/producto/impresion-digital" class="py-2 border-l-2 border-offsetti-blue pl-4">Impresión digital</a>
        <a href="/producto/encuadernacion" class="py-2 border-l-2 border-offsetti-blue pl-4">Encuadernación</a>
        <a href="/producto/personalizacion" class="py-2 border-l-2 border-offsetti-blue pl-4">Personalización</a>
      </div>
    </div>

    <a href="/producto" class="border-b border-gray-50 py-4">Producto</a>
    <a href="/logistica" class="border-b border-gray-50 py-4">Logística</a>
    <a href="/imprenta-ecologica" class="border-b border-gray-50 py-4">Imprenta ecológica</a>
    <a href="/contacto" class="py-4 text-offsetti-blue">Contacto</a>
  </nav>
</div>

    </div>
  </div>
</header>

<script>
  const menuToggle = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');

  menuToggle?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
    
    // Opcional: Cambiar el icono de hamburguesa a una "X" al abrir
    const isOpen = !mobileMenu?.classList.contains('hidden');
    if (menuIcon) {
        menuIcon.innerHTML = isOpen 
            ? '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />' 
            : '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />';
    }
  });

  // Cerrar el menú si se hace click fuera (mejor UX)
  document.addEventListener('click', (event) => {
    const isClickInside = menuToggle?.contains(event.target as Node) || mobileMenu?.contains(event.target as Node);
    if (!isClickInside && !mobileMenu?.classList.contains('hidden')) {
      mobileMenu?.classList.add('hidden');
      if (menuIcon) menuIcon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />';
    }
  });

  const submenuBtn = document.getElementById('mobile-submenu-btn');
  const submenuList = document.getElementById('mobile-submenu-list');
  const arrow = document.getElementById('mobile-arrow');

  submenuBtn?.addEventListener('click', (e) => {
    e.preventDefault(); // Evita que el botón haga scroll o cosas raras
    submenuList?.classList.toggle('hidden');
    submenuList?.classList.toggle('flex');
    
    // Rotar la flecha
    arrow?.classList.toggle('rotate-180');
  });
</script>

<style>
    /* Aseguramos que el header se mantenga siempre arriba al hacer scroll */
    header {
        transition: all 0.3s ease;
    }
</style>
