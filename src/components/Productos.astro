---
import { Image } from 'astro:assets';
import imgCalendario from '../assets/productos-home/calendario-1.png';
import imgCarpetas from '../assets/productos-home/carpetas-1.png';
import imgDesplegables from '../assets/productos-home/desplegables.png';
import imgDisplay from '../assets/productos-home/display-1.png';
import imgEdicionEncuadernado from '../assets/productos-home/edicion-encuadernacion-2.png';
import imgEspiral1b from '../assets/productos-home/espiral-1B.png';
import imgEspiral2 from '../assets/productos-home/espiral-2.png';
import imgEstuche from '../assets/productos-home/estuche-1.png';
import imgMoleskine from '../assets/productos-home/moleskine-1B.png';
import imgPack from '../assets/productos-home/pack-1.png';
import imgRigidos from '../assets/productos-home/rigidos-1.png';
import imgFondo from '../assets/productos-home/fondo-producto.svg';

const products = [
    { alt: 'producto 1', src: imgCalendario},
    { alt: 'producto 1', src: imgCarpetas},
    { alt: 'producto 1', src: imgDesplegables},
    { alt: 'producto 1', src: imgDisplay},
    { alt: 'producto 1', src: imgEdicionEncuadernado},
    { alt: 'producto 1', src: imgEspiral1b},
    { alt: 'producto 1', src: imgEspiral2},
    { alt: 'producto 1', src: imgEstuche},
    { alt: 'producto 1', src: imgMoleskine},
    { alt: 'producto 1', src: imgPack},
    { alt: 'producto 1', src: imgRigidos}
]
---
<section class="py-20 overflow-hidden w-full">
  <div class="carousel-container relative flex">
    <div id="carousel-track" class="flex gap-10 animate-scroll">
      {products.map((product) => (
        <div class="carousel-item flex-shrink-0">
          <div class="relative h-[300px] md:h-[450px] aspect-[4/5] flex items-center justify-center p-6">
            
            <div class="absolute inset-0 z-0 flex items-end justify-end">
               <Image 
                 src={imgFondo} 
                 alt="fondo decorativo" 
                 class="w-[100%] h-[45%] object-cover object-right-bottom" 
               />
            </div>

            <div class="relative z-10 w-full h-full flex items-center justify-center">
              <Image 
                src={product.src} 
                alt={product.alt} 
                class="max-w-[90%] max-h-[90%] object-contain drop-shadow-2xl transform group-hover:scale-105 transition-transform duration-500" 
              />
            </div>

          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .carousel-container {
    width: 100%;
    /* mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent); */
  }

  .animate-scroll {
    display: flex;
    width: max-content;
    animation: scroll 40s linear infinite;
  }

  /* Pausar al pasar el mouse (opcional, muy profesional) */
  .animate-scroll:hover {
    animation-play-state: paused;
  }

  @keyframes scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      /* Se moverá la mitad del ancho total (que es el set original) */
      transform: translateX(-50%);
    }
  }

  .carousel-item img {
    user-select: none;
    -webkit-user-drag: none;
  }    
</style>

<script>
  function setupCarousel() {
    const track = document.getElementById('carousel-track');
    if (!track) return;

    // Clonamos el contenido una vez para que cuando el primero termine, 
    // el segundo ya esté entrando y no se vea el hueco blanco.
    const items = track.innerHTML;
    track.innerHTML = items + items;
  }

  // Ejecutar al cargar y si usas View Transitions de Astro
  setupCarousel();
  document.addEventListener('astro:after-swap', setupCarousel);
</script>